# notebooks/svm_model.sav

# ==============================================
# Pip a balíčky (pip and packages)
# ==============================================
*.egg-info/
dist/
build/
*.egg

# ==============================================
# Různé systémové soubory (misc system files)
# ==============================================
.DS_Store
Thumbs.db
CACHEDIR.TAG
pyvenv.cfg

