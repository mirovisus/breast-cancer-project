# ==============================================
# Virtuální prostředí (Virtual environment)
# ==============================================
.venv/
venv/
env/
ENV/

# ==============================================
# Python cache soubory (Python cache files)
# ==============================================
__pycache__/
*.py[cod]
*$py.class
*.pyc

# ==============================================
# Jupyter Notebook checkpointy
# ==============================================
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# ==============================================
# VS Code nastavení (VS Code settings)
# ==============================================
.vscode/

# ==============================================
# Datové soubory - Housing dataset (nechceme sdílet)
# ==============================================
data/HousingData.csv

# ==============================================
# Vzorový (ukázkový) projekt - nechceme sdílet
# ==============================================
notebooks/vzorovy_projekt.ipynb

# ==============================================
